{
  // App-side config: the browser/Vue source under src/. It's a "composite"
  // project referenced by the root solution file (tsconfig.json).
  //
  // As with tsconfig.node.json, a referenced project may not set "noEmit"
  // (that triggers TS6310), so instead of disabling emit we send all generated
  // output into a gitignored throwaway folder inside node_modules.
  "compilerOptions": {
    "composite": true,
    "outDir": "./node_modules/.tmp/tsconfig.app",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["vite/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.vue", "env.d.ts"]
}
