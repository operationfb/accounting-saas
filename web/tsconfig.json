{
  // Root "solution" config: it owns no files of its own ("files": []) and just
  // points at the two real projects. `vue-tsc --build` walks these references
  // and type-checks each one. This is the standard modern Vite + Vue 3 layout:
  //   - tsconfig.app.json  -> browser/Vue source under src/
  //   - tsconfig.node.json -> Node-side tooling (vite.config.ts)
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ]
}
