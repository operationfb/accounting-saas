# Non-secret environment for the dev Cloud Run service.
#
# Copy this file to deployment/env.dev.yaml and fill each value from the project's
# root .env — these are all NON-secret config. (Secrets go to Secret Manager
# instead, injected via --set-secrets; see deployment/README.md.) The copy,
# deployment/env.dev.yaml, is gitignored.
#
# Deploy reads it with:  gcloud run deploy ... --env-vars-file deployment/env.dev.yaml
#
# Deliberately NOT listed here:
#   PORT                           - reserved; Cloud Run injects it (the app reads $PORT)
#   WEB_DIST_DIR                   - baked into the image (=/web) by the Dockerfile
#   GOOGLE_APPLICATION_CREDENTIALS - Cloud Run uses the attached service account (ADC)
#   CORS_ALLOWED_ORIGINS           - same-origin SPA, so CORS is unused
#   APP_BASE_URL                   - set AFTER the first deploy (= the service URL)
#   DATABASE_URL, PASETO_SYMMETRIC_KEY, MAILGUN_INBOUND_SIGNING_KEY, SMTP_PASSWORD
#                                  - secrets, injected via --set-secrets

# Receipt-attachment storage (Google Cloud Storage bucket name)
GCS_BUCKET: "your-bucket-name"

# Document AI (OCR). Location "eu" keeps extraction in-region.
DOCAI_PROJECT_ID: "your-gcp-project-id"
DOCAI_LOCATION: "eu"
DOCAI_INVOICE_PROCESSOR_ID: "your-invoice-processor-id"
DOCAI_EXPENSE_PROCESSOR_ID: "your-expense-processor-id"

# Email-to-expense (Mailgun inbound). Domain only; the signing key is a secret.
INBOX_DOMAIN: "your-inbox-domain"

# HTML-body receipt rendering (Gotenberg service URL)
GOTENBERG_URL: "https://your-gotenberg-url"

# Outbound email (password-reset). The password is a secret (smtp-password).
SMTP_HOST: "smtp.example.com"
SMTP_PORT: "587"
SMTP_USERNAME: "you@example.com"
EMAIL_FROM: "you@example.com"

# Public base URL of the app (same origin serves the SPA + API). Builds password-reset
# links {APP_BASE_URL}/reset-password/…. Listed here (rather than set post-deploy)
# because the automated --env-vars-file deploy replaces the full env set every build.
APP_BASE_URL: "https://app.kontala.com"

API_PUBLIC_URL: "https://app.kontala.com"
PUBSUB_EXPENSE_APPROVED_TOPIC: "expense-approved"
GOOGLE_CLOUD_PROJECT: "stocks-ag"
WORKFLOW_SERVICE_ACCOUNT: "freeagent-push-wf@stocks-ag.iam.gserviceaccount.com"
FREEAGENT_SANDBOX: "true"